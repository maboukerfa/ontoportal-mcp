#!/usr/bin/env ruby
# frozen_string_literal: true

# Entry point for the AgroPortal MCP server (stdio transport).
#
# MCP clients (Claude Desktop, Claude Code, ...) spawn this with an arbitrary
# working directory, so pin the bundle to this project's Gemfile explicitly.
ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../../Gemfile', __FILE__)
require 'bundler/setup'

require_relative '../lib/agroportal_mcp'

AgroportalMcp.run
